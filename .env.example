# CIPRB M&E Intelligence Platform
# Environment Variables Configuration

# Django Settings
SECRET_KEY=your_secure_django_secret_key_here
DEBUG=True

# Database Configuration (PostgreSQL/Supabase)
# Required for production. For local dev with SQLite, you can omit this or use sqlite:///db.sqlite3
DATABASE_URL=postgresql://user:password@hostname:port/dbname

# External APIs
# Required for generating the AI Newsletter
GEMINI_API_KEY=your_gemini_api_key_here

# KoboToolbox Webhook Secret
# Required to authenticate incoming POST requests from KoboToolbox
KOBO_WEBHOOK_SECRET=your_kobo_webhook_secret_here
